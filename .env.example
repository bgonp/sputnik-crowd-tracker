# Scraper credentials — copy to .env and fill in.
# The scraper (scraper/src/index.ts) reads these to write readings to Turso.

# Turso database URL.
#   Remote:     libsql://<your-db>.turso.io
#   Local mock: file:../dev.db   (no auth token needed)
TURSO_URL=libsql://your-db.turso.io

# Turso auth token (omit / leave blank when using a local file: URL).
TURSO_AUTH_TOKEN=your-token-here
