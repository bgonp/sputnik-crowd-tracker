# Dashboard config — copy to .env.local and fill in.
# Server components read these to query Turso (see src/lib/db.ts).

# Turso database URL.
#   Remote:     libsql://<your-db>.turso.io
#   Local mock: file:../dev.db   (used by `pnpm dev:mock`; no auth token needed)
TURSO_URL=libsql://your-db.turso.io

# READ-ONLY token — the dashboard only reads. Create one with:
#   turso db tokens create <db> --read-only
# For a local file: URL the value is ignored, but keep this line (set it empty,
# i.e. `TURSO_AUTH_TOKEN=`) rather than removing it.
TURSO_AUTH_TOKEN=your-read-only-token

# Optional: freeze "now" to a fixed ISO timestamp for reproducible views/tests.
# MOCK_NOW=2026-06-13T18:30:00Z

# Optional: public base URL for canonical links, Open Graph, sitemap & robots.
# On Vercel this falls back to the injected production URL; locally it defaults
# to http://localhost:3000. Set it only for a custom production domain.
# NEXT_PUBLIC_SITE_URL=https://your-domain.com
