# Scraper local-dev config — copy to .env (git-ignored) and fill in.
# The package scripts load this automatically via `--env-file-if-exists=.env`.
# In production the scraper runs on the Raspberry Pi, which supplies these
# through its service environment (systemd/cron) rather than this file.

# Turso database URL (same database as the dashboard).
TURSO_URL=libsql://your-db.turso.io

# READ-WRITE token — the scraper is the only writer. Create one with:
#   turso db tokens create <db>
TURSO_AUTH_TOKEN=your-read-write-token
